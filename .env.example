# 애플리케이션 설정
NODE_ENV=development
APP_PORT=3000
APP_NAME=nestjs-oracle-app

# Oracle/Tibero 데이터베이스 설정
DB_USER=your_username
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=ORCL

# 로깅 설정
LOG_LEVEL=debug
LOG_DIR=./logs

# 기타 설정
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_POOL_TIMEOUT=60
